{
  "name": "@benjaminbini/paged-editor-web",
  "version": "1.9.17",
  "description": "Vanilla JS iframe embed for paged-editor — no React required",
  "repository": {
    "type": "git",
    "url": "https://github.com/BenjaminBini/paged-editor.git",
    "directory": "packages/web"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "@benjaminbini/paged-editor-base": ">=1.4.0"
  },
  "devDependencies": {
    "@benjaminbini/paged-editor-base": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
