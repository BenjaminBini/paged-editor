{
  "name": "@benjaminbini/paged-editor-base",
  "version": "1.9.21",
  "description": "Shared static assets for paged-editor (index.html, js/**, css/**, assets/) with Node.js server helper",
  "repository": {
    "type": "git",
    "url": "https://github.com/BenjaminBini/paged-editor.git",
    "directory": "packages/base"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc && node scripts/emit-markdown-features.mjs && node -e \"require('fs').cpSync('assets','dist/assets',{recursive:true,force:true})\"",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    "./server": {
      "require": "./server.cjs",
      "import": "./server.mjs",
      "types": "./server.d.ts"
    }
  },
  "files": [
    "server.cjs",
    "server.mjs",
    "server.d.ts",
    "index.html",
    "dist/",
    "css/",
    "assets/"
  ],
  "devDependencies": {
    "@codemirror/lint": "^6.8.0",
    "jsdom": "^24.1.0",
    "marked": "^15.0.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
